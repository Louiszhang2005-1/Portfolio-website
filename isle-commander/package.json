{
  "name": "isle-commander",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/safe-dev.ps1",
    "dev:next": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "dev:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/safe-dev.ps1 -Port 3010 -SmokeTestSeconds 12",
    "dev:turbo": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "node ./scripts/vercel-next-build.mjs",
    "postbuild": "node ./scripts/ensure-vercel-routes-manifest.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/matter-js": "^0.20.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "matter-js": "^0.20.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
    "@tailwindcss/oxide-linux-x64-musl": "^4.2.2",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-linux-x64-musl": "^1.32.0"
  }
}
